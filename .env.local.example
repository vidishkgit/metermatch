# Copy to .env.local and fill in. Also set these in Vercel project settings.

# sample = bundled demo data (default). aws = live Aurora + DynamoDB.
DATA_SOURCE=sample
# Mirror of DATA_SOURCE exposed to the browser (drives the topbar "AWS live" badge).
NEXT_PUBLIC_DATA_SOURCE=sample

# Period to scan (YYYY-MM). Matches the seeded invoices.
SCAN_PERIOD=2026-05

# --- AWS credentials ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- DynamoDB (usage events) ---
DYNAMO_USAGE_TABLE=metermatch_usage_events

# --- Aurora PostgreSQL via RDS Data API (billing) ---
AURORA_CLUSTER_ARN=
AURORA_SECRET_ARN=
AURORA_DATABASE=metermatch

# --- Auth ---
# Long random strings. Generate with:  openssl rand -base64 32
SESSION_SECRET=dev-insecure-secret-change-in-production
OTP_SECRET=dev-otp-secret
# DynamoDB table that stores hashed OTPs (TTL on `expiresAt`). Omit to use the
# in-memory fallback (fine for single-process local dev).
DYNAMO_AUTH_TABLE=metermatch_auth_otps
# Verified SES sender. Omit to log codes to the server console instead of emailing.
SES_FROM_EMAIL=
